    {
      "parameters": {
        "jsCode": "const batchId = $input.first().json.batch_id;\nreturn [{ json: { batch_id: batchId } }];"
      },
      "id": "aa33f262-f24d-4b88-9146-ba37f2d3e165",
      "name": "Set Batch ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1552,
        -176
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  d.subject,\n  d.file_name,\n  c.category_nme,\n  d.is_deductible,\n  d.review_status\nFROM core.tax_documents d\nJOIN ref.tax_categories c ON c.category_id = d.tax_category_id\nWHERE d.review_status IN ('CONFIRMED', 'REJECTED')\n  AND d.tax_category_id IS NOT NULL\nORDER BY d.updated_at DESC NULLS LAST\nLIMIT 10;",
        "options": {}
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef000000001a",
      "name": "Get Few-Shot Examples",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        1712,
        -96
      ],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "GhZL6n0TTt2R9eJ7",
          "name": "Tax Collector DB"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT landing_id, subject, sender_email, file_name, file_ext\nFROM landing.tax_documents\nWHERE is_processed = FALSE\n  AND raw_json -> 'classification' IS NULL;",
        "options": {}
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef000000002b",
      "name": "Get Unclassified Landing",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        1900,
        -176
      ],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "GhZL6n0TTt2R9eJ7",
          "name": "Tax Collector DB"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const OLLAMA_URL = 'http://192.168.0.93:11434/api/generate';\nconst MODEL = 'qwen2.5:14b';\nconst CATEGORIES = [\n  'Payment Summary / Income Statement', 'Bank Interest', 'Dividends',\n  'Share Trade / CGT Event', 'Work From Home — Electricity/Gas',\n  'Work From Home — Internet', 'Technology Equipment', 'Software & Subscriptions',\n  'Professional Development', 'Income Protection Insurance',\n  'ATO Notice / Assessment', 'HECS-HELP', 'Superannuation',\n  'Private Health Insurance', 'Rental Income', 'Property Depreciation',\n  'Utility Bill', 'Motor Vehicle / Logbook', 'Donations',\n  'Tax Agent Fees', 'Work-Related Assets', 'Other'\n];\n\nconst examples = $items('Get Few-Shot Examples').map(i => i.json);\nconst fewShotBlock = examples.length >= 3\n  ? 'Here are recent examples of correctly classified documents:\\n' +\n    examples.map(e => `- \"${e.subject || e.file_name}\" → ${e.category_nme} (deductible: ${e.is_deductible})`).join('\\n') + '\\n\\n'\n  : '';\n\nconst records = $input.all().filter(i => i.json && i.json.landing_id != null).map(i => i.json);\nif (records.length === 0) return [{ json: { classified: 0, updates: [] } }];\n\nconst updates = await Promise.all(records.map(async (rec) => {\n  const prompt = `${fewShotBlock}Classify this tax document for Australian personal tax records.\\nSubject: ${rec.subject || '—'}\\nSender: ${rec.sender_email || '—'}\\nFile: ${rec.file_name || '—'}\\n\\nCategories:\\n${CATEGORIES.map(c => '- ' + c).join('\\n')}\\n\\nAlso determine:\\n- fy_year: Australian financial year (e.g. 2025). Null if unclear.\\n- supplier_name: issuing company\\n- is_deductible: true/false\\n- confidence: 0.0 to 1.0\\n\\nRespond ONLY with valid JSON:\\n{\"category\": \"...\", \"fy_year\": 2025, \"supplier_name\": \"...\", \"is_deductible\": false, \"confidence\": 0.85}`;\n\n  let classification;\n  try {\n    const resp = await fetch(OLLAMA_URL, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ model: MODEL, prompt, stream: false })\n    });\n    const data = await resp.json();\n    const raw = (data.response || '').replace(/```json\\n?/g, '').replace(/```/g, '').trim();\n    classification = JSON.parse(raw);\n  } catch (e) {\n    classification = { category: 'Other', fy_year: null, supplier_name: null, is_deductible: false, confidence: 0.0 };\n  }\n\n  return { landing_id: rec.landing_id, classification };\n}));\n\nreturn [{ json: { classified: updates.length, updates } }];"
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef000000003c",
      "name": "Classify Landing Records",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        -176
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-classified-gt-zero",
