    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE landing.tax_documents AS t\nSET raw_json = t.raw_json || jsonb_build_object('classification', u.cls)\nFROM (\n  SELECT\n    (el->>'landing_id')::int AS lid,\n    (el->>'classification')::jsonb AS cls\n  FROM jsonb_array_elements(\n    '{{ JSON.stringify($json.updates) }}'::jsonb\n  ) AS el\n) u\nWHERE t.landing_id = u.lid;",
        "options": {}
      },
