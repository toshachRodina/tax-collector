{
  "name": "EXTRACT_GMAIL",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst exitCode = item.json.exitCode;\nconst stdout = item.json.stdout || '';\nconst stderr = item.json.stderr || '';\nif (exitCode !== 0) {\n  return [{ json: { success: false, exitCode, stdout, stderr } }];\n}\nreturn [{ json: { success: true, exitCode, stdout, stderr } }];"
      },
      "id": "436442dc-80d3-4b8f-ab48-67dc98e275f7",
      "name": "Check Exit Code",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5072,
        352
      ]
    },
    {
      "parameters": {
        "command": "=timeout 570 python3 /data/tax-collector/scripts/process_document.py --file '{{ $json.stagingPath }}' --meta-encoded '{{ $json.metaEncoded }}' --source-type GMAIL"
      },
      "id": "f809cb5d-d297-486c-a5c9-0a8103cc738e",
      "name": "Write and Process",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        4880,
        352
