    },
    {
      "parameters": {
        "jsCode": "const nodeFs = require('fs');\nconst nodePath = require('path');\nconst pdfData = $json.pdfData;\nconst stagingPath = $json.stagingPath;\n\nif (!pdfData) { return []; }\n\nconst b64 = pdfData.replace(/-/g, '+').replace(/_/g, '/');\nconst padded = b64 + '='.repeat((4 - b64.length % 4) % 4);\nconst buf = Buffer.from(padded, 'base64');\n\nnodeFs.mkdirSync(nodePath.dirname(stagingPath), { recursive: true });\nnodeFs.writeFileSync(stagingPath, buf);\n\nreturn [{ json: {\n  stagingPath: $json.stagingPath,\n  metaEncoded: $json.metaEncoded\n} }];"
      },
      "id": "417ee982-91b3-45ac-b33b-e1d15ed35549",
      "name": "Write PDF with fs",
