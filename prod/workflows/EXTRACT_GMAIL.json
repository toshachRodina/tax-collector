        "query": "SELECT COALESCE(\n    (EXTRACT(EPOCH FROM (MAX(received_at) - INTERVAL '3 days')) * 1000)::bigint,\n    EXTRACT(EPOCH FROM TIMESTAMP '2022-07-01 00:00:00+00')::bigint * 1000\n) AS watermark_ms\nFROM core.tax_documents\nWHERE source_type = 'GMAIL';",
        "options": {}
