    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction isPdfPart(p) {\n  var mt = (p.mimeType || '').toLowerCase();\n  var fn = (p.filename || '').toLowerCase();\n  return mt.indexOf('pdf') !== -1 || fn.endsWith('.pdf');\n}\n\nfunction findPdfAttachments(parts) {\n  var found = [];\n  if (!parts || !Array.isArray(parts)) return found;\n  for (var i = 0; i < parts.length; i++) {\n    var p = parts[i];\n    var hasContent = p.body && (p.body.attachmentId || (p.body.data && p.body.data.length > 0));\n    if (isPdfPart(p) && hasContent) {\n      found.push({ attachmentId: p.body.attachmentId || null, inlineData: p.body.data || null,\n        filename: p.filename || 'attachment.pdf', mimeType: p.mimeType || 'application/pdf' });\n    }\n    if (p.parts) {\n      var nested = findPdfAttachments(p.parts);\n      for (var j = 0; j < nested.length; j++) found.push(nested[j]);\n    }\n  }\n  return found;\n}\n\nreturn items.map(function(item) {\n  var msg = item.json;\n  var messageId = String(msg.id || '');\n  var parts = (msg.payload && msg.payload.parts) ? msg.payload.parts : [];\n  var attachments = findPdfAttachments(parts);\n\n  if (attachments.length === 0 && msg.payload) {\n    var p = msg.payload;\n    var hasContent = p.body && (p.body.attachmentId || (p.body.data && p.body.data.length > 0));\n    if (isPdfPart(p) && hasContent) {\n      attachments = [{ attachmentId: p.body.attachmentId || null, inlineData: p.body.data || null,\n        filename: p.filename || 'attachment.pdf', mimeType: p.mimeType || 'application/pdf' }];\n    }\n  }\n\n  var headers = (msg.payload && msg.payload.headers) ? msg.payload.headers : [];\n  var subject = '', sender = '';\n  headers.forEach(function(h) {\n    var n = (h.name || '').toLowerCase();\n    if (n === 'subject') subject = h.value || '';\n    if (n === 'from') sender = h.value || '';\n  });\n\n  var batchId = null;\n  try { batchId = $items('Start Batch')[0].json.batch_id; } catch(e) {}\n\n  var first = attachments.length > 0 ? attachments[0] : null;\n  var filename = first ? first.filename : 'attachment.pdf';\n  var safeName = filename.replace(/[\\/:\"*?<>|]/g, '_');\n  var stagingPath = '/data/tax-collector/staging/' + messageId + '_' + safeName;\n  var receivedAt = msg.internalDate ? new Date(parseInt(msg.internalDate)).toISOString() : new Date().toISOString();\n  var metaObj = { source_id: messageId, subject: subject, sender_email: sender,\n    received_at: receivedAt, file_name: filename,\n    file_ext: filename.split('.').pop().toLowerCase(), file_size_bytes: null };\n  var metaEncoded = encodeURIComponent(JSON.stringify(metaObj)).replace(/'/g, '%27');\n\n  if (!first) {\n    return { json: { messageId, stagingPath, metaEncoded, batchId, subject, sender, filename, receivedAt, _noAttachmentFound: true } };\n  }\n  return { json: { messageId, attachmentId: first.attachmentId, inlineData: first.inlineData,\n    filename, safeName, stagingPath, metaEncoded, batchId, subject, sender, receivedAt, _noAttachmentFound: false } };\n});"
      },
