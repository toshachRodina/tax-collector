    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst afterDate = new Date(parseInt(items[0].json.watermark_ms, 10));\n\nconst batchId = $items(\"Start Batch\")[0].json.batch_id;\n\nconst fmt = (d) => d.getFullYear() + '/' + String(d.getMonth()+1).padStart(2,'0') + '/' + String(d.getDate()).padStart(2,'0');\n\nconst today = new Date();\nconst query = 'has:attachment filename:pdf after:' + fmt(afterDate) + ' before:' + fmt(today);\n\nreturn [{ json: { query, batchId, afterDate: afterDate.toISOString(), beforeDate: today.toISOString() } }];"
      },
