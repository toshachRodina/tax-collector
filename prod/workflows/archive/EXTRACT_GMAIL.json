    {
      "parameters": {
        "jsCode": "const today = new Date();\nconst fyEndYear = today.getMonth() >= 6 ? today.getFullYear() + 1 : today.getFullYear();\n\n// TEMP: 3-month window for testing â€” revert to watermark after end-to-end test passes\nconst afterDate = new Date(Date.now() - 90 * 24 * 60 * 60 * 1000);\n\nconst batchId = $items(\"Start Batch\")[0].json.batch_id;\n\nconst fmt = (d) => `${d.getFullYear()}/${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')}`;\nconst fyEndDate = new Date(fyEndYear, 5, 30);\nconst beforeDate = today < fyEndDate ? today : fyEndDate;\n\nconst query = `has:attachment filename:pdf after:${fmt(afterDate)} before:${fmt(beforeDate)}`;\n\nreturn [{ json: { query, batchId, fyEndYear, afterDate: afterDate.toISOString(), beforeDate: beforeDate.toISOString() } }];"
      },
