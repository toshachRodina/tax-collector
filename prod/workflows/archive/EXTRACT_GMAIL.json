    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COALESCE(\n    MAX(EXTRACT(EPOCH FROM received_at) * 1000)::bigint,\n    CASE\n        WHEN EXTRACT(MONTH FROM CURRENT_DATE) >= 7\n        THEN EXTRACT(EPOCH FROM MAKE_DATE(EXTRACT(YEAR FROM CURRENT_DATE)::int - 1, 7, 1))::bigint * 1000\n        ELSE EXTRACT(EPOCH FROM MAKE_DATE(EXTRACT(YEAR FROM CURRENT_DATE)::int - 2, 7, 1))::bigint * 1000\n    END\n) AS watermark_ms\nFROM core.tax_documents\nWHERE 1 = 1\n  AND source_type = 'GMAIL';",
        "options": {}
